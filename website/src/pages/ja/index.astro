---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import WhyBokuchi from '../../components/WhyBokuchi.astro';
import Features from '../../components/Features.astro';
import ThemeGallery from '../../components/ThemeGallery.astro';
import SupportedLanguages from '../../components/SupportedLanguages.astro';
import Download from '../../components/Download.astro';

const title = 'Bokuchi - 無料・軽量マークダウンエディタ（macOS / Windows / Linux）';
const description = '無料・オフラインで使えるマークダウンエディタ。アカウント不要。macOS / Windows / Linux 対応。リアルタイムプレビュー、KaTeX数式、Mermaidダイアグラム、マルチタブ、14言語対応。';
---

<Layout
  title={title}
  description={description}
  locale="ja"
  canonicalURL={new URL(Astro.url.pathname, Astro.site)}
>
  <Hero locale="ja" />
  <WhyBokuchi locale="ja" />
  <Features locale="ja" />
  <ThemeGallery locale="ja" />
  <SupportedLanguages locale="ja" />
  <Download locale="ja" />
</Layout>
